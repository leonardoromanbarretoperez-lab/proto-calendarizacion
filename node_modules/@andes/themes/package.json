{
  "name": "@andes/themes",
  "version": "9.6.5",
  "main": "./main.js",
  "types": "./index.d.ts",
  "files": [
    "build",
    "meli-themes",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/metrics": {
      "development": {
        "types": "./lib/metrics/metrics.d.ts",
        "node": "./build/cjs/metrics/node-index.development.js",
        "require": "./build/cjs/metrics/index.development.js",
        "import": "./build/esm/metrics/index.development.js"
      },
      "default": {
        "types": "./lib/metrics/metrics.d.ts",
        "node": "./build/cjs/metrics/node-index.production.js",
        "require": "./build/cjs/metrics/index.production.js",
        "import": "./build/esm/metrics/index.production.js"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "test": "node ../../scripts/test.js",
    "clean": "node ../../scripts/clean.js",
    "lint": "node ../../scripts/sass-lint.js"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "dependencies": {
    "@andes/common": "9.6.5",
    "@andes/context": "9.6.5",
    "prop-types": "^15.5.10"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  }
}
