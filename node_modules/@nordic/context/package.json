{
  "name": "@nordic/context",
  "version": "9.19.1",
  "description": "Nordic context",
  "author": "Nordic <nordic@mercadolibre.com>",
  "homepage": "https://github.com/melisource/fury_nordic#readme",
  "license": "UNLICENSED",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "development": {
        "node": "./dist/cjs/index.development.js",
        "default": "./dist/esm/index.browser.development.mjs"
      },
      "node": "./dist/cjs/index.production.js",
      "default": "./dist/esm/index.browser.production.mjs"
    },
    "./internal": {
      "types": "./dist/types/internal.d.ts",
      "development": {
        "node": "./dist/cjs/internal.development.js",
        "default": "./dist/esm/internal.browser.development.mjs"
      },
      "node": "./dist/cjs/internal.production.js",
      "default": "./dist/esm/internal.browser.production.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melisource/fury_nordic.git",
    "directory": "packages/context"
  },
  "bugs": {
    "url": "https://github.com/melisource/fury_nordic/issues"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "NODE_ENV=development rollup -c rollup.config.mjs",
    "dist": "npm run build && NODE_ENV=production rollup -c rollup.config.mjs",
    "test": "echo \"Error: run tests from root\" && exit 1"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "dependencies": {
    "@nordic/core-context": "9.19.1",
    "@nordic/rendering-context": "9.19.1",
    "@nordic/utils": "9.19.1"
  },
  "engines": {
    "node": "^22.12 || ^24.11"
  }
}
