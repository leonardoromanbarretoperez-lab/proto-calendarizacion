{
  "name": "@andes/dropdown",
  "version": "9.6.5",
  "description": "A dropdown component that can be used in forms or standalone.",
  "main": "./main.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.scss"
  ],
  "files": [
    "build",
    "lib/**/*.scss",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "index.scss",
    "base.scss"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "test": "node ../../scripts/test.js",
    "clean": "node ../../scripts/clean.js",
    "lint": "node ../../scripts/sass-lint.js"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@andes/checkbox": "9.6.5",
    "@andes/common": "9.6.5",
    "@andes/context": "9.6.5",
    "@andes/floating-menu": "9.6.5",
    "@andes/form": "9.6.5",
    "@andes/icons": "9.6.5",
    "@andes/list": "9.6.5",
    "@andes/tag": "9.6.5",
    "@andes/themes": "9.6.5",
    "@andes/visually-hidden": "9.6.5",
    "@react-aria/focus": "3.21.1",
    "@react-aria/interactions": "3.25.5",
    "@react-aria/ssr": "3.9.10",
    "@react-aria/utils": "3.30.1",
    "@react-stately/flags": "3.1.2",
    "@react-stately/utils": "3.10.8",
    "@react-types/shared": "3.32.0",
    "@swc/helpers": "0.5.17",
    "classnames": "^2.2.5",
    "prop-types": "^15.5.10",
    "react-innertext": "1.1.5"
  },
  "devDependencies": {
    "@andes/shadow-dom": "9.6.5"
  },
  "eslintConfig": {
    "globals": {
      "document": true,
      "IntersectionObserver": true
    }
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "gitHead": "0e65f7e4b94c7730bfbb519e46798a5936919690"
}
