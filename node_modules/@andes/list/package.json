{
  "name": "@andes/list",
  "version": "9.6.5",
  "description": "A collection of styled options.",
  "main": "./main.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.scss"
  ],
  "files": [
    "build",
    "lib/**/*.scss",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "index.scss",
    "base.scss"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/generators/*": {
      "development": {
        "types": "./lib/generators/generators.d.ts",
        "require": "./build/cjs/generators/*.development.js",
        "import": "./build/esm/generators/*.development.js"
      },
      "default": {
        "types": "./lib/generators/generators.d.ts",
        "require": "./build/cjs/generators/*.production.js",
        "import": "./build/esm/generators/*.production.js"
      }
    },
    "./build/utils/*": {
      "development": {
        "types": "./lib/utils/utils.d.ts",
        "require": "./build/cjs/utils/*.development.js",
        "import": "./build/esm/utils/*.development.js"
      },
      "default": {
        "types": "./lib/utils/utils.d.ts",
        "require": "./build/cjs/utils/*.production.js",
        "import": "./build/esm/utils/*.production.js"
      }
    },
    "./build/context/*": {
      "development": {
        "types": "./lib/context/context.d.ts",
        "require": "./build/cjs/context/*.development.js",
        "import": "./build/esm/context/*.development.js"
      },
      "default": {
        "types": "./lib/context/context.d.ts",
        "require": "./build/cjs/context/*.production.js",
        "import": "./build/esm/context/*.production.js"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "test": "node ../../scripts/test.js",
    "clean": "node ../../scripts/clean.js",
    "lint": "node ../../scripts/sass-lint.js"
  },
  "devDependencies": {
    "@andes/badge": "9.6.5",
    "@andes/switch": "9.6.5",
    "@andes/thumbnail": "9.6.5",
    "react-virtualized-auto-sizer": "^1.0.7",
    "react-window": "^1.8.8",
    "react-window-infinite-loader": "^1.0.7"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "dependencies": {
    "@andes/common": "9.6.5",
    "@andes/context": "9.6.5",
    "@andes/icons": "9.6.5",
    "@andes/image": "9.6.5",
    "@andes/themes": "9.6.5",
    "@andes/with-tracker": "9.6.5",
    "@babel/runtime": "^7.14.8",
    "@react-aria/focus": "3.21.1",
    "@react-aria/interactions": "3.25.5",
    "@react-aria/ssr": "3.9.10",
    "@react-aria/utils": "3.30.1",
    "@react-stately/flags": "3.1.2",
    "@react-stately/utils": "3.10.8",
    "@react-types/shared": "3.32.0",
    "@swc/helpers": "0.5.17",
    "classnames": "^2.2.5",
    "prop-types": "^15.5.10"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "gitHead": "0e65f7e4b94c7730bfbb519e46798a5936919690"
}
