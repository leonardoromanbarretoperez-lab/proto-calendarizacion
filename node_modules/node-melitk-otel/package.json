{
  "name": "node-melitk-otel",
  "version": "2.6.1",
  "description": "OpenTelemetry out-of-the-box Tracer Provider for Node.js apps",
  "prettier": "@meli-lint/eslint-config-base/prettier-config",
  "scripts": {
    "clean": "rm -rf lib node_modules package-lock.json",
    "predist": "rm -rf lib",
    "dist": "tsc -p ./tsconfig.json",
    "build": "tsc -p ./tsconfig.dev.json",
    "prettify": "prettier --write .",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "watch": "NODE_ENV=development tsc --watch",
    "lint": "eslint './*.[jt]s' './**/*.[jt]s'",
    "lint:fix": "eslint './*.[jt]s' './**/*.[jt]s' --fix",
    "lint:ts": "eslint src/index.ts 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/melisource/fury_node-melitk-otel.git"
  },
  "author": "",
  "license": "private",
  "bugs": {
    "url": "https://github.com/melisource/fury_node-melitk-otel/issues"
  },
  "files": [
    "lib"
  ],
  "exports": {
    ".": "./lib/index.js",
    "./opentelemetry/api": "./lib/opentelemetry/api.js",
    "./opentelemetry/custom-span": "./lib/opentelemetry/custom-span.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "^20.12 || ^22.12 || ^24.11"
  },
  "peerDependencies": {
    "@grpc/grpc-js": "^1.12.5"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^2.2.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.208.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/instrumentation-express": "0.50.0",
    "@opentelemetry/instrumentation-http": "^0.208.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.22.0",
    "@opentelemetry/propagator-b3": "^2.2.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "frontend-env": "^4.0.1",
    "frontend-restclient": "^5.1.6"
  },
  "devDependencies": {
    "@meli-lint/eslint-config-base-ts": "^5.1.0",
    "@meli-lint/eslint-config-tests-jest": "^5.1.0",
    "@meli/ts-config": "^2.3.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "node-forge": ">=1.3.2",
    "axios": ">=1.13.5",
    "flatted": ">=3.4.2"
  }
}
