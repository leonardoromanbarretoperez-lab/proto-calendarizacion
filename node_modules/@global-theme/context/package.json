{
  "name": "@global-theme/context",
  "version": "1.6.0",
  "description": "Global theme context management for server and client",
  "homepage": "https://github.com/melisource/fury_global-theme-web#readme",
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "development": {
        "node": "./dist/cjs/index.development.js",
        "default": "./dist/esm/index.browser.development.mjs"
      },
      "node": "./dist/cjs/index.production.js",
      "default": "./dist/esm/index.browser.production.mjs"
    },
    "./server": {
      "types": "./dist/types/server.d.ts",
      "development": "./dist/cjs/server.development.js",
      "default": "./dist/cjs/server.production.js"
    },
    "./internal": {
      "types": "./dist/types/internal.d.ts",
      "development": {
        "node": "./dist/cjs/internal.development.js",
        "default": "./dist/esm/internal.browser.development.mjs"
      },
      "node": "./dist/cjs/internal.production.js",
      "default": "./dist/esm/internal.browser.production.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melisource/fury_global-theme-web.git",
    "directory": "packages/context"
  },
  "bugs": {
    "url": "https://github.com/melisource/fury_global-theme-web/issues"
  },
  "scripts": {
    "build": "NODE_ENV=development rollup -c rollup.config.mjs",
    "dist": "npm run build && NODE_ENV=production rollup -c rollup.config.mjs",
    "watch": "NODE_ENV=development rollup -c rollup.config.mjs -w",
    "test": "jest -c ../../jest.config.js"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "dependencies": {
    "@global-theme/core": "1.6.0",
    "serialize-javascript": "^7.0.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.24",
    "@types/serialize-javascript": "^5.0.2"
  }
}
