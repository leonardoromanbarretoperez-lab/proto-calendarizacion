{
  "name": "@andes/listbox",
  "version": "9.6.5",
  "description": "ListBox presents a list of options and allows a user to select one or more of them",
  "main": "./main.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.scss"
  ],
  "files": [
    "build",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "index.scss"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "test": "node ../../scripts/test.js",
    "clean": "node ../../scripts/clean.js",
    "lint": "node ../../scripts/sass-lint.js"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "dependencies": {
    "@andes/common": "9.6.5",
    "@andes/list": "9.6.5",
    "@internationalized/date": "3.9.0",
    "@internationalized/message": "3.1.8",
    "@internationalized/number": "3.6.5",
    "@internationalized/string": "3.2.7",
    "@react-aria/focus": "3.21.1",
    "@react-aria/i18n": "3.12.12",
    "@react-aria/interactions": "3.25.5",
    "@react-aria/label": "3.7.21",
    "@react-aria/listbox": "3.14.8",
    "@react-aria/selection": "3.25.1",
    "@react-aria/ssr": "3.9.10",
    "@react-aria/utils": "3.30.1",
    "@react-stately/collections": "3.12.7",
    "@react-stately/flags": "3.1.2",
    "@react-stately/list": "3.13.0",
    "@react-stately/selection": "3.20.5",
    "@react-stately/utils": "3.10.8",
    "@react-types/listbox": "3.7.3",
    "@react-types/shared": "3.32.0",
    "@swc/helpers": "0.5.17",
    "classnames": "^2.2.5",
    "prop-types": "^15.5.10"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  }
}
