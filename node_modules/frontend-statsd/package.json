{
  "name": "frontend-statsd",
  "version": "3.1.0",
  "description": "Allows you to have custom metrics from your server",
  "author": "Frontend Core Team <frontendcore@mercadolibre.com>",
  "prettier": "@meli-lint/eslint-config-base/prettier-config",
  "homepage": "https://github.com/melisource/fury_frontend-statsd#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melisource/fury_frontend-statsd.git"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./internal": {
      "types": "./types/internal.d.ts",
      "default": "./src/internal.js"
    },
    "./package.json": "./package.json"
  },
  "bugs": {
    "url": "https://github.com/melisource/fury_frontend-statsd/issues"
  },
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "test": "npm run test:unit",
    "test:unit": "jest && npm run test:types",
    "test:types": "tsc",
    "lint": "npm run lint:js",
    "lint:js": "eslint .",
    "prettify": "prettier . --write"
  },
  "files": [
    "src",
    "types"
  ],
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "dependencies": {
    "@meli/deprecation": "^1.4.1",
    "@meli/statsd": "^1.4.1",
    "frontend-config": "^3.0.0",
    "frontend-env": "^4.0.1"
  },
  "devDependencies": {
    "@meli-lint/eslint-config-base": "^5.0.2",
    "@meli-lint/eslint-config-tests-jest": "^5.0.2",
    "@types/jest": "^30.0.0",
    "eslint": "^9.31.0",
    "jest": "^30.0.5",
    "prettier": "^3.6.2",
    "typescript": "^5.8.2"
  },
  "license": "UNLICENSED"
}
