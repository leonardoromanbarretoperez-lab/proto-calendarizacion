{
  "name": "frontend-logger",
  "version": "3.1.0",
  "description": "A simple and fast logging module for Node.js applications.",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "node": "./src/index.js",
      "default": "./lib/browser.js"
    }
  },
  "files": [
    "src",
    "lib",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mercadolibre/fury_frontend-logger.git"
  },
  "prettier": "@meli-lint/eslint-config-base/prettier-config",
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "test": "npm run test:unit",
    "test:unit": "jest --coverage && npm run test:types",
    "test:unit:watch": "jest --watch",
    "test:types": "tsc",
    "lint": "eslint .",
    "prettify": "prettier . --write",
    "dist": "mkdir -p lib && babel ./src --out-dir ./lib --ignore src/Logger.js --ignore src/index.js"
  },
  "author": "Front-end Core <frontendcore@mercadolibre.com>",
  "dependencies": {
    "@meli/logger": "^1.6.1"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@meli-lint/eslint-config-nordic": "5.1.1",
    "@types/jest": "29.5.14",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "prettier": "3.8.1",
    "test-console": "2.0.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "^20.12 || ^22.12 || >=24.11"
  }
}
