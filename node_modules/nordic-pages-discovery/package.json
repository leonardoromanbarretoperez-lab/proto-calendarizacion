{
  "name": "nordic-pages-discovery",
  "version": "2.2.1",
  "description": "discovery of Nordic Pages and the information they need to work",
  "prettier": "@meli-lint/eslint-config-base/prettier-config",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "test": "npm run test:unit && npm run test:integration && npm run test:types",
    "test:types": "tsc",
    "test:unit": "jest --coverage tests/unit",
    "test:integration": "jest --coverage tests/integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettify": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/melisource/fury_nordic-pages-discovery.git"
  },
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/melisource/fury_nordic-pages-discovery/issues"
  },
  "files": [
    "lib",
    "index.d.ts",
    "island.d.ts"
  ],
  "engines": {
    "node": "^22.12 || >=24.11"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@meli/logger": "^1.6.2",
    "glob": "^13.0.6",
    "lodash": "^4.18.1",
    "nordic-babel-alias-resolver": "^4.2.0"
  },
  "devDependencies": {
    "@meli-lint/eslint-config-base": "^4.6.0",
    "@meli-lint/eslint-config-tests-jest": "^4.6.0",
    "@types/jest": "^30.0.0",
    "eslint": "^8.57.1",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
