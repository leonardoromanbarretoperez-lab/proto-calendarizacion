{
  "name": "@andes/button",
  "version": "9.6.5",
  "description": "Buttons used for a variety of actions.",
  "main": "./main.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.scss"
  ],
  "files": [
    "build",
    "translations",
    "lib/**/*.scss",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "index.scss",
    "base.scss"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "test": "node ../../scripts/test.js",
    "clean": "node ../../scripts/clean.js",
    "lint": "node ../../scripts/sass-lint.js",
    "postinstall": "meli-i18n add-translations ./translations"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@andes/common": "9.6.5",
    "@andes/context": "9.6.5",
    "@andes/floating-menu": "9.6.5",
    "@andes/progress-indicator-circular": "9.6.5",
    "@andes/themes": "9.6.5",
    "@andes/visually-hidden": "9.6.5",
    "classnames": "^2.2.5",
    "prop-types": "^15.5.10"
  },
  "devDependencies": {
    "@andes/icons": "9.6.5"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "gitHead": "0e65f7e4b94c7730bfbb519e46798a5936919690"
}
