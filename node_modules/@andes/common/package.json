{
  "name": "@andes/common",
  "version": "9.6.5",
  "description": "Common Sass variables, mixins and functions to use all across Andes.",
  "main": "./main.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.scss"
  ],
  "files": [
    "build",
    "lib/**/*.scss",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "index.scss",
    "variables.scss",
    "secondary-palette.scss",
    "mixins.scss",
    "functions.scss"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/utils/*": {
      "development": {
        "types": "./lib/utils/utils.d.ts",
        "require": "./build/cjs/utils/*.development.js",
        "import": "./build/esm/utils/*.development.js"
      },
      "default": {
        "types": "./lib/utils/utils.d.ts",
        "require": "./build/cjs/utils/*.production.js",
        "import": "./build/esm/utils/*.production.js"
      }
    },
    "./build/metrics": {
      "development": {
        "types": "./lib/metrics/metrics.d.ts",
        "node": "./build/cjs/metrics/node-index.development.js",
        "require": "./build/cjs/metrics/index.development.js",
        "import": "./build/esm/metrics/index.development.js"
      },
      "default": {
        "types": "./lib/metrics/metrics.d.ts",
        "node": "./build/cjs/metrics/node-index.production.js",
        "require": "./build/cjs/metrics/index.production.js",
        "import": "./build/esm/metrics/index.production.js"
      }
    },
    "./build/webkit/*": {
      "development": {
        "types": "./lib/webkit/webkit.d.ts",
        "require": "./build/cjs/webkit/*.development.js",
        "import": "./build/esm/webkit/*.development.js"
      },
      "default": {
        "types": "./lib/webkit/webkit.d.ts",
        "require": "./build/cjs/webkit/*.production.js",
        "import": "./build/esm/webkit/*.production.js"
      }
    },
    "./build/hooks/*": {
      "development": {
        "types": "./lib/hooks/hooks.d.ts",
        "require": "./build/cjs/hooks/*.development.js",
        "import": "./build/esm/hooks/*.development.js"
      },
      "default": {
        "types": "./lib/hooks/hooks.d.ts",
        "require": "./build/cjs/hooks/*.production.js",
        "import": "./build/esm/hooks/*.production.js"
      }
    },
    "./build/constants/*": {
      "development": {
        "types": "./lib/constants/constants.d.ts",
        "require": "./build/cjs/constants/*.development.js",
        "import": "./build/esm/constants/*.development.js"
      },
      "default": {
        "types": "./lib/constants/constants.d.ts",
        "require": "./build/cjs/constants/*.production.js",
        "import": "./build/esm/constants/*.production.js"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "test": "npm run lint",
    "lint": "node ../../scripts/sass-lint.js",
    "clean": "node ../../scripts/clean.js"
  },
  "dependencies": {
    "@andes/close-listener": "9.6.5",
    "@andes/image": "9.6.5",
    "@andes/visually-hidden": "9.6.5",
    "@andes/widther": "9.6.5",
    "@react-aria/ssr": "3.9.10",
    "@react-aria/utils": "3.30.1",
    "@react-stately/flags": "3.1.2",
    "@react-stately/utils": "3.10.8",
    "@react-types/shared": "3.32.0",
    "@swc/helpers": "0.5.17",
    "base32-encode": "^1.0.0",
    "classnames": "^2.2.5",
    "exenv": "1.2.2",
    "prop-types": "^15.5.10",
    "warning": "4.0.2"
  },
  "devDependencies": {
    "@types/exenv": "1.2.0"
  },
  "peerDependencies": {
    "frontend-env": "^4.0.1",
    "frontend-statsd": "^3.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "gitHead": "0e65f7e4b94c7730bfbb519e46798a5936919690"
}
