{
  "name": "@andes/floating-menu",
  "version": "9.6.5",
  "description": "Floating Menu is a card with lists that overlaps the rest of the UI",
  "main": "./main.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.scss"
  ],
  "files": [
    "build",
    "translations",
    "lib/**/*.scss",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "index.scss",
    "base.scss"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "test": "node ../../scripts/test.js",
    "clean": "node ../../scripts/clean.js",
    "lint": "node ../../scripts/sass-lint.js",
    "postinstall": "meli-i18n add-translations ./translations"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "dependencies": {
    "@andes/checkbox": "9.6.5",
    "@andes/common": "9.6.5",
    "@andes/context": "9.6.5",
    "@andes/icons": "9.6.5",
    "@andes/list": "9.6.5",
    "@andes/listbox": "9.6.5",
    "@andes/popper": "9.6.5",
    "@andes/themes": "9.6.5",
    "@andes/visually-hidden": "9.6.5",
    "@andes/with-tracker": "9.6.5",
    "@react-aria/focus": "3.21.1",
    "@react-aria/interactions": "3.25.5",
    "@react-aria/ssr": "3.9.10",
    "@react-aria/utils": "3.30.1",
    "@react-stately/flags": "3.1.2",
    "@react-stately/utils": "3.10.8",
    "@react-types/shared": "3.32.0",
    "@swc/helpers": "0.5.17",
    "classnames": "^2.2.5",
    "prop-types": "^15.5.10"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  }
}
