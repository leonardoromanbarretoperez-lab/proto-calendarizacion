{
  "name": "@andes/textfield",
  "description": "Form input controls.",
  "version": "9.6.5",
  "main": "./main.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.scss"
  ],
  "files": [
    "build",
    "translations",
    "lib/**/*.scss",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "index.scss",
    "base.scss"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/scripts/*": {
      "development": {
        "require": "./build/cjs/scripts/*.development.js",
        "import": "./build/esm/scripts/*.development.js"
      },
      "default": {
        "require": "./build/cjs/scripts/*.production.js",
        "import": "./build/esm/scripts/*.production.js"
      }
    },
    "./masks/*": {
      "development": {
        "types": "./lib/masks/masks.d.ts",
        "require": "./build/cjs/masks/*/index.development.js",
        "import": "./build/esm/masks/*/index.development.js"
      },
      "default": {
        "types": "./lib/masks/masks.d.ts",
        "require": "./build/cjs/masks/*/index.production.js",
        "import": "./build/esm/masks/*/index.production.js"
      }
    },
    "./masks": {
      "development": {
        "types": "./lib/masks/masks.d.ts",
        "require": "./build/cjs/masks/index.development.js",
        "import": "./build/esm/masks/index.development.js"
      },
      "default": {
        "types": "./lib/masks/masks.d.ts",
        "require": "./build/cjs/masks/index.production.js",
        "import": "./build/esm/masks/index.production.js"
      }
    },
    "./hooks/*": {
      "development": {
        "types": "./lib/hooks/hooks.d.ts",
        "require": "./build/cjs/hooks/*.development.js",
        "import": "./build/esm/hooks/*.development.js"
      },
      "default": {
        "types": "./lib/hooks/hooks.d.ts",
        "require": "./build/cjs/hooks/*.production.js",
        "import": "./build/esm/hooks/*.production.js"
      }
    },
    "./build/masks/*": {
      "development": {
        "types": "./lib/masks/masks.d.ts",
        "require": "./build/cjs/masks/*/index.development.js",
        "import": "./build/esm/masks/*/index.development.js"
      },
      "default": {
        "types": "./lib/masks/masks.d.ts",
        "require": "./build/cjs/masks/*/index.production.js",
        "import": "./build/esm/masks/*/index.production.js"
      }
    },
    "./build/masks": {
      "development": {
        "types": "./lib/masks/masks.d.ts",
        "require": "./build/cjs/masks/index.development.js",
        "import": "./build/esm/masks/index.development.js"
      },
      "default": {
        "types": "./lib/masks/masks.d.ts",
        "require": "./build/cjs/masks/index.production.js",
        "import": "./build/esm/masks/index.production.js"
      }
    },
    "./build/hooks/*": {
      "development": {
        "types": "./lib/hooks/hooks.d.ts",
        "require": "./build/cjs/hooks/*.development.js",
        "import": "./build/esm/hooks/*.development.js"
      },
      "default": {
        "types": "./lib/hooks/hooks.d.ts",
        "require": "./build/cjs/hooks/*.production.js",
        "import": "./build/esm/hooks/*.production.js"
      }
    },
    "./build/utils/*": {
      "development": {
        "types": "./lib/utils/utils.d.ts",
        "require": "./build/cjs/utils/*.development.js",
        "import": "./build/esm/utils/*.development.js"
      },
      "default": {
        "types": "./lib/utils/utils.d.ts",
        "require": "./build/cjs/utils/*.production.js",
        "import": "./build/esm/utils/*.production.js"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "node ../../scripts/clean.js",
    "postinstall": "meli-i18n add-translations ./translations"
  },
  "devDependencies": {
    "@andes/autocomplete": "9.6.5",
    "@andes/button": "9.6.5",
    "@andes/checkbox": "9.6.5",
    "@andes/tooltip": "9.6.5",
    "@types/autosize": "^4.0.1"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "dependencies": {
    "@andes/common": "9.6.5",
    "@andes/context": "9.6.5",
    "@andes/dropdown": "9.6.5",
    "@andes/form": "9.6.5",
    "@andes/icons": "9.6.5",
    "@andes/progress-indicator-circular": "9.6.5",
    "@andes/themes": "9.6.5",
    "@andes/visually-hidden": "9.6.5",
    "@react-aria/focus": "3.21.1",
    "@react-aria/interactions": "3.25.5",
    "@react-aria/ssr": "3.9.10",
    "@react-aria/utils": "3.30.1",
    "@react-stately/flags": "3.1.2",
    "@react-stately/utils": "3.10.8",
    "@react-types/shared": "3.32.0",
    "@swc/helpers": "0.5.17",
    "autosize": "^4.0.1",
    "classnames": "^2.2.5",
    "prop-types": "^15.5.10"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "gitHead": "0e65f7e4b94c7730bfbb519e46798a5936919690"
}
