{
  "name": "@andes/icons",
  "version": "9.6.5",
  "description": "Andes Icons set",
  "sideEffects": false,
  "types": "./index.d.ts",
  "files": [
    "esm",
    "cjs",
    "index.d.ts",
    "*.d.ts"
  ],
  "exports": {
    "./*": {
      "types": "./*.d.ts",
      "require": "./cjs/*.js",
      "import": "./esm/*.js"
    },
    ".": {
      "types": "./index.d.ts",
      "require": "./cjs",
      "import": "./esm"
    }
  },
  "scripts": {
    "clean": "node ../../scripts/clean.js"
  },
  "dependencies": {
    "classnames": "^2.2.5",
    "prop-types": "^15.5.10"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "author": "Frontend Core",
  "license": "ISC"
}
