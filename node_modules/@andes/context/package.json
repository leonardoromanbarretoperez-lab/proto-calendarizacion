{
  "name": "@andes/context",
  "version": "9.6.5",
  "description": "Context allows passing common global props & params to Andes components",
  "main": "./main.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.scss"
  ],
  "files": [
    "build",
    "main.js",
    "main.mjs",
    "dev-main.mjs",
    "index.d.ts",
    "index.js",
    "index.mjs"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./dev-main.mjs"
      },
      "default": {
        "types": "./index.d.ts",
        "require": "./main.js",
        "import": "./main.mjs"
      }
    },
    "./build/*": {
      "require": "./build/cjs/*",
      "import": "./build/esm/*"
    },
    "./*": "./*"
  },
  "scripts": {
    "test": "node ../../scripts/test.js",
    "clean": "node ../../scripts/clean.js",
    "lint": "node ../../scripts/sass-lint.js"
  },
  "author": "Frontend Core",
  "license": "ISC",
  "gitHead": "0e65f7e4b94c7730bfbb519e46798a5936919690",
  "dependencies": {
    "@andes/common": "9.6.5",
    "@meli/i18n": "^1.0.0",
    "prop-types": "^15.5.10"
  },
  "peerDependencies": {
    "@nordic/context": "^9.0.0",
    "@nordic/i18n": "^9.0.0",
    "react": "^19.0.0"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  }
}
