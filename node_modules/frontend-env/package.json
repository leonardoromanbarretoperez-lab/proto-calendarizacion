{
  "name": "frontend-env",
  "version": "4.1.0",
  "description": "Get common environment variables.",
  "files": [
    "src",
    "types"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/melisource/fury_frontend-env.git"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "lint": "eslint .",
    "test": "npm run test:unit",
    "test:unit": "NODE_ENV=test SCOPE=test_scope APPLICATION=test_app PLATFORM=test_fury NODE_HTTPS=true jest ./test/*.spec.js --coverage && npm run test:types",
    "test:types": "tsc"
  },
  "author": "FeCore <frontendcore@mercadolibre.com>",
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "devDependencies": {
    "@meli-lint/eslint-config-nordic": "4.5.0",
    "@types/node": "^20.17.10",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "typescript": "5.7.2"
  }
}
