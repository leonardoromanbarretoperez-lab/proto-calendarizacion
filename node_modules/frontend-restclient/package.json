{
  "name": "frontend-restclient",
  "version": "5.3.0",
  "description": "A promise-based RestClient for Node and Browser.",
  "author": "Front-end Core <frontendcore@mercadolibre.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/melisource/fury_frontend-restclient.git"
  },
  "files": [
    "lib",
    "src",
    "config",
    "types"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "node": "./src/index.js",
      "default": "./lib/browser.js"
    },
    "./cancel": {
      "types": "./types/cancel.d.ts",
      "default": "./src/cancel.js"
    },
    "./src/build-context": "./src/build-context.js",
    "./src/build-flow-context": "./src/build-flow-context.js",
    "./package.json": "./package.json"
  },
  "prettier": "@meli-lint/eslint-config-base/prettier-config",
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "lint": "NODE_ENV=test eslint '*.js' 'src/**/*.js' 'test/**/*.spec.js' 'config/**/*js'",
    "test": "npm run test:unit",
    "test:unit": "jest -i && npm run test:types",
    "test:unit:watch": "NODE_ENV=test jest --watch",
    "test:unit:debug": "NODE_ENV=test node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand --config jest.config.js",
    "test:types": "tsc",
    "dist": "mkdir -p lib && babel ./src/browser.js --out-file ./lib/browser.js && babel ./config/defaults.browser.js --out-file ./lib/defaults.js"
  },
  "engines": {
    "node": "^22.12 || >=24.11.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "dependencies": {
    "@meli/logger": "^1.6.2",
    "@meli/server-context": "^1.5.3",
    "@meli/statsd": "^1.6.2",
    "axios": "^1.15.2",
    "frontend-env": "^4.1.0",
    "retry": "0.13.1",
    "stale-lru-cache": "5.1.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@meli-lint/eslint-config-nordic": "4.6.0",
    "@meli/ts-config": "2.3.0",
    "@types/express": "^4.17.25",
    "@types/jest": "30.0.0",
    "@types/node": "^22.19.19",
    "@types/stale-lru-cache": "5.1.6",
    "babel-jest": "30.4.1",
    "eslint": "^8.57.1",
    "frontend-mocks": "3.1.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  }
}
