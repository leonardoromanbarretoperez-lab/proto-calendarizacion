{
  "name": "frontend-country_config",
  "version": "3.1.2",
  "description": "A set of country-specific data for formatting and parsing",
  "author": "Front-end Core <frontendcore@mercadolibre.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/melisource/fury_frontend-country-config.git"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "config",
    "utils",
    "types/index.d.ts"
  ],
  "prettier": "@meli-lint/eslint-config-base/prettier-config",
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "test": "npm run test:unit",
    "test:unit": "jest && npm run test:types",
    "test:types": "tsc",
    "lint": "npm run lint:js",
    "lint:js": "eslint .",
    "lint:fix": "npm run lint:js -- --fix",
    "prettify": "prettier --write .",
    "update-data": "node ./update.js"
  },
  "dependencies": {
    "frontend-env": "^4.0.1",
    "frontend-restclient": "^5.0.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@meli-lint/eslint-config-base": "5.1.1",
    "@meli-lint/eslint-config-base-ts": "5.1.1",
    "@meli-lint/eslint-config-tests-jest": "5.1.1",
    "@types/express": "4.17.25",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.23",
    "eslint": "9.39.2",
    "frontend-platform_detection": "3.2.0",
    "jest": "30.2.0",
    "nock": "14.0.11",
    "node-mocks-http": "1.17.2",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  }
}
