{
  "name": "@meli/i18n",
  "version": "1.6.2",
  "description": "Lib to manage internationalization in your ExpressJS app",
  "author": "Nordic <nordic@mercadolibre.com>",
  "homepage": "https://github.com/melisource/fury_node-common-libs#readme",
  "license": "UNLICENSED",
  "files": [
    "bin",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/i18n.d.ts",
      "node": {
        "import": "./dist/esm/i18n.mjs",
        "default": "./dist/cjs/i18n.js"
      },
      "require": "./dist/cjs/i18n.js",
      "default": "./dist/browser/i18n.mjs"
    },
    "./middleware": {
      "types": "./dist/types/middleware/index.d.ts",
      "import": "./dist/esm/middleware/index.mjs",
      "default": "./dist/cjs/middleware/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "meli-i18n": "./bin/i18n.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melisource/fury_node-common-libs.git",
    "directory": "packages/i18n"
  },
  "scripts": {
    "build": "NODE_ENV=development rollup -c rollup.config.mjs",
    "dist": "NODE_ENV=production rollup -c rollup.config.mjs",
    "test": "echo \"Error: run tests from root\" && exit 1"
  },
  "bugs": {
    "url": "https://github.com/melisource/fury_node-common-libs/issues"
  },
  "dependencies": {
    "@meli/statsd": "1.6.2",
    "frontend-country_config": "^3.0.0",
    "frontend-env": "^4.0.1",
    "node-melitk-otel": "^2.2.4"
  },
  "engines": {
    "node": "^20.12 || ^22.12 || >=24.11"
  }
}
