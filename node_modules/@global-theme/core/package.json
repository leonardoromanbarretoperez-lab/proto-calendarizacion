{
  "name": "@global-theme/core",
  "version": "1.6.0",
  "description": "Global theme management for Mercado Libre's frontend applications",
  "homepage": "https://github.com/melisource/fury_global-theme-web#readme",
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "development": "./dist/cjs/index.development.js",
      "default": "./dist/cjs/index.production.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melisource/fury_global-theme-web.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/melisource/fury_global-theme-web/issues"
  },
  "scripts": {
    "build": "NODE_ENV=development rollup -c rollup.config.mjs",
    "dist": "npm run build && NODE_ENV=production rollup -c rollup.config.mjs",
    "watch": "NODE_ENV=development rollup -c rollup.config.mjs -w",
    "test": "jest -c ../../jest.config.js"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  },
  "dependencies": {
    "@meli/server-context": "^1.3.4",
    "deepmerge": "^4.3.1",
    "frontend-config": "^3.0.5",
    "frontend-logger": "^3.0.0",
    "frontend-restclient": "^5.1.1",
    "frontend-statsd": "^3.0.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.24",
    "frontend-platform_detection": "^3.0.0"
  }
}
