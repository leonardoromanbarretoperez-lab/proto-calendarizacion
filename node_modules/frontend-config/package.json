{
  "name": "frontend-config",
  "version": "3.3.5",
  "description": "Flexible configuration for Node.js applications",
  "author": "Front-end Core <frontendcore@mercadolibre.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/mercadolibre/frontend-config.git"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.mjs",
      "default": "./src/index.js"
    },
    "./config/platforms": "./config/platforms.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json",
    "test": "npm run test:unit",
    "test:unit": "npm run dist && npm run validate && NODE_ENV=test NODE_CONFIG='{\"env_var\": 123}' NODE_CONFIG_DIR=test/fixtures/config jest --coverage && npm run test:types",
    "test:unit:watch": "NODE_ENV=test NODE_CONFIG='{\"env_var\": 123}' NODE_CONFIG_DIR=test/fixtures/config jest --watch",
    "test:unit:debug": "NODE_ENV=test NODE_CONFIG='{\"env_var\": 123}' NODE_CONFIG_DIR=test/fixtures/config node --inspect-brk=5005 ./node_modules/.bin/jest --runInBand",
    "test:types": "tsc",
    "dist": "npm run build",
    "build": "node ./utils/build.js && node ./types/generator/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate:debug": "node --inspect-brk=5005 ./test/validations/index.js",
    "validate": "node ./test/validations/index.js"
  },
  "keywords": [],
  "files": [
    "index.d.ts",
    "src",
    "config",
    "utils"
  ],
  "dependencies": {
    "@meli/logger": "^1.6.2",
    "@meli/statsd": "^1.4.3",
    "frontend-env": "^4.0.1",
    "frontend-restclient": "^5.1.2",
    "json5": "^2.2.3",
    "lodash": "^4.17.21",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@babel/runtime": "7.28.4",
    "@meli-lint/eslint-config-base": "1.0.0",
    "@types/express": "^4.17.23",
    "@types/jest": "^30.0.0",
    "eslint": "8.57.1",
    "frontend-mocks": "3.0.1",
    "frontend-platform_detection": "3.1.0",
    "jest": "30.2.0",
    "semver": "7.7.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "^20.12 || >=22.12"
  }
}
